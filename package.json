{
  "name": "@workspace/discord-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --enable-source-maps --import tsx/esm src/index.ts",
    "deploy-commands": "node --enable-source-maps --import tsx/esm src/deploy-commands.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "node --enable-source-maps --import tsx/esm src/deploy-commands.ts && node --enable-source-maps --import tsx/esm src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "discord.js": "^14.16.3",
    "drizzle-orm": "catalog:",
    "pg": "^8.20.0",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
